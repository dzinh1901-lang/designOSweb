# ══════════════════════════════════════════════════════════
# DESIGNOS BACKEND · Environment Configuration
# Copy to .env — NEVER commit .env to version control
# ══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Security ─────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('hex')|pbcopy"
JWT_SECRET=CHANGE_ME_64_BYTE_RANDOM_HEX
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_BYTE_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AES-256-GCM field-level encryption key (32 bytes hex)
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX
ENCRYPTION_KEY_VERSION=1

# HMAC for signed URLs / webhook verification
HMAC_SECRET=CHANGE_ME_HMAC_SECRET

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS=false
REDIS_PREFIX=dos:

# ── Kafka ─────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=designos-gateway
KAFKA_GROUP_ID=designos-workers
KAFKA_TOPIC_RENDERS=dos.renders
KAFKA_TOPIC_QA=dos.qa
KAFKA_TOPIC_NOTIFICATIONS=dos.notifications
KAFKA_SSL=false

# ── Firebase / Firestore ──────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── AWS S3 ────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_ASSETS=designos-assets
S3_BUCKET_OUTPUTS=designos-outputs
CLOUDFRONT_DOMAIN=https://cdn.yourdomain.com

# ── Pinecone ──────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=designos-embeddings
PINECONE_ENVIRONMENT=us-east-1-aws

# ── AI Model APIs ─────────────────────────────────────────
KLING_API_KEY=your-kling-api-key
KLING_API_BASE=https://api.klingai.com/v1
KLING_API_VERSION=3.0

GENSPARK_API_KEY=your-genspark-api-key
GENSPARK_API_BASE=https://api.genspark.ai/v1

ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

FLUX_API_KEY=your-flux-api-key
FLUX_API_BASE=https://api.bfl.ml/v1

SUNO_API_KEY=your-suno-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── FastAPI Orchestrator ──────────────────────────────────
ORCHESTRATOR_URL=http://localhost:8001
ORCHESTRATOR_INTERNAL_SECRET=CHANGE_ME_INTERNAL_SECRET

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERATE_MAX=20

# ── File Upload ───────────────────────────────────────────
MAX_FILE_SIZE_MB=50
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ── Observability ─────────────────────────────────────────
LOG_LEVEL=info
METRICS_PORT=9090
ENABLE_TRACING=false
SENTRY_DSN=
