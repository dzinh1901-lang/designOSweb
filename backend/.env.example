# ══════════════════════════════════════════════════════════
# DESIGNOS Backend — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ORCHESTRATOR_PORT=8001

# ── Security secrets (generate with: openssl rand -hex 32) ─
JWT_SECRET=CHANGE_ME_32_CHAR_MIN_jwt_secret_here
JWT_EXPIRES_IN=15m
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_MIN_encryption_key
ENCRYPTION_KEY_VERSION=1
HMAC_SECRET=CHANGE_ME_32_CHAR_MIN_hmac_secret_key
ORCHESTRATOR_INTERNAL_SECRET=CHANGE_ME_32_CHAR_MIN_internal_secret

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=designos_redis_secret
REDIS_PREFIX=dos:

# ── Kafka ──────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=designos-gateway
KAFKA_SSL=false
KAFKA_UI_PASSWORD=designos_kafka_ui

# ── Firebase / Firestore ──────────────────────────────────
FIRESTORE_PROJECT_ID=your-firebase-project-id
# Path to your Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# ── AWS S3 + CloudFront ───────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=designos-assets-prod
S3_KMS_KEY_ID=                          # Optional: ARN of KMS key for SSE-KMS
CLOUDFRONT_DOMAIN=assets.yourdomain.com
CLOUDFRONT_KEY_PAIR_ID=                 # CloudFront key pair ID for signed URLs
CLOUDFRONT_PRIVATE_KEY=                 # PEM-encoded private key (single line, escaped \n)

# ── Branding ──────────────────────────────────────────────
BRAND_LOGO_URL=https://assets.yourdomain.com/brand/logo.png

# ── AI / ML APIs ──────────────────────────────────────────

# Anthropic Claude 3.5 Sonnet (Director Agent - prompt structuring)
ANTHROPIC_API_KEY=sk-ant-...

# Kling 3.0 Video Generation
KLING_API_KEY=your_kling_api_key
KLING_API_BASE=https://api.klingai.com/v1

# Genspark AI (Creative Expansion)
GENSPARK_API_KEY=your_genspark_api_key
GENSPARK_API_BASE=https://api.genspark.ai/v1

# Google Gemini 2.5 Flash (Scene analysis, multi-modal)
GOOGLE_API_KEY=your_google_api_key

# OpenAI (optional fallback for enrichment)
OPENAI_API_KEY=sk-...

# Replicate (SDXL Turbo + Flux.1)
REPLICATE_API_TOKEN=r8_...

# fal.ai (alternative diffusion backend)
FAL_AI_KEY=your_fal_ai_key

# Pinecone (vector search for style embeddings)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX_NAME=designos-embeddings

# ElevenLabs (voiceover / audio)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Suno v4 (background music)
SUNO_API_KEY=your_suno_api_key

# ── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_GENERATE_MAX=20

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info

# ── Metrics ────────────────────────────────────────────────
METRICS_SECRET=CHANGE_ME_metrics_endpoint_secret

# ── Orchestrator URL (gateway → orchestrator) ─────────────
ORCHESTRATOR_URL=http://localhost:8001

# ── Optional: QA/CLIP service ─────────────────────────────
CLIP_SERVICE_URL=                       # External CLIP score service
OPTICAL_FLOW_SERVICE_URL=               # External optical flow service
